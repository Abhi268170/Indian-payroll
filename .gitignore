# EF Core migrations — Designer.cs files must be committed. Without them
# EF Core cannot discover the migration (the [Migration] attribute + the
# BuildTargetModel snapshot live in Designer.cs). Ignoring this file
# silently turns committed migrations into no-ops.

# Secrets — NEVER commit
secrets/
*.pfx
*.p12

